# ============================================================
# .env.example  –  copy to .env and fill in your values
# NEVER commit the real .env to version control
# ============================================================

# Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=student_management
DB_USERNAME=smsuser
DB_PASSWORD=changeme_strong_password

# MySQL root (docker-compose only)
MYSQL_ROOT_PASSWORD=changeme_root_password

# JWT – generate with: openssl rand -hex 32
JWT_SECRET=replace_with_64_hex_chars_minimum_256_bits
JWT_EXPIRY_MS=86400000
JWT_REFRESH_EXPIRY_MS=604800000

# Mail (optional)
MAIL_ENABLED=false
MAIL_USERNAME=your@gmail.com
MAIL_PASSWORD=your_app_password

# Spring profile: dev | prod | test
SPRING_PROFILES_ACTIVE=prod
